rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }

    function isOrderParticipant(orderData) {
      return isSignedIn() && (
        orderData.customerId == request.auth.uid ||
        orderData.storeOwnerId == request.auth.uid ||
        orderData.driverId == request.auth.uid
      );
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantOwner(restaurantId);
    }

    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    match /orders/{orderId} {
      // Allow list based on simple, single-field queries
      allow list: if isSignedIn() && (
        // Customer can list their own orders
        request.query.customerId == request.auth.uid ||
        
        // Owner can list orders for their restaurant
        request.query.storeOwnerId == request.auth.uid ||
        
        // Driver can list orders they have accepted OR see available orders
        request.query.driverId == request.auth.uid ||
        request.query.status == 'Preparing'
      );
      
      // Customer: Can create an order for themselves.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      // Read access based on role
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.storeOwnerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );

      // Update access with field validation
      allow update: if isSignedIn() && (
        // Customer can cancel order
        (resource.data.customerId == request.auth.uid && 
         request.resource.data.keys().hasOnly(['status']) && 
         request.resource.data.status in ['Cancelled']) ||
        
        // Restaurant owner can update status
        (resource.data.storeOwnerId == request.auth.uid && 
         request.resource.data.keys().hasOnly(['status', 'estimatedTime', 'readyTime'])) ||
        
        // Driver can accept order (set driverId and update status)
        (request.resource.data.driverId == request.auth.uid && 
         resource.data.driverId == null &&
         request.resource.data.keys().hasAll(['driverId', 'status']) &&
         request.resource.data.status in ['Out for Delivery']) ||
        
        // Driver can mark as delivered
        (resource.data.driverId == request.auth.uid &&
         request.resource.data.keys().hasOnly(['status']) &&
         request.resource.data.status == 'Delivered')
      );
      
      // Customer can delete/cancel their own order
      allow delete: if isSignedIn() && resource.data.customerId == request.auth.uid;

      match /orderItems/{orderItemId} {
        // Read access same as parent order
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.storeOwnerId == request.auth.uid
        );
        
        // Only the customer can add items when creating order
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid;
      }
    }
  }
}
