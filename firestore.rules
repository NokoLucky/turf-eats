rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RELAXED RULES FOR TESTING
    // This broad match allows all reads and writes to any document and collection group.
    // This is intended to unblock development and testing of the Admin Dashboard.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}