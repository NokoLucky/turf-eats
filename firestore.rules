rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.storeOwnerId);
    }

    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    match /orders/{orderId} {
      // Combined list rule for customers and owners.
      allow list: if isSignedIn() && (request.query.where.customerId == request.auth.uid || request.query.where.storeOwnerId == request.auth.uid);
      
      // Customer: Can create an order.
      allow create: if isSignedIn();
      
      // Customer: Can read their own order.
      // Owner: Can read orders for their restaurant.
      allow read: if isOwner(resource.data.customerId) || isOwner(resource.data.storeOwnerId);

      // Owner/Driver: Can update status.
      // Customer: Can update (e.g. to cancel).
      allow update: if isOwner(resource.data.customerId) || isOwner(resource.data.storeOwnerId) || isOwner(resource.data.driverId);
      
      // Customer: Can delete their own order.
      allow delete: if isOwner(resource.data.customerId);

      match /orderItems/{orderItemId} {
        // Access is inherited from the parent order document.
        allow read: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.customerId) || isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.storeOwnerId);
        // Only the order creator can create items for it (done in a batch).
        allow create: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.customerId);
    }
    }
  }
}
