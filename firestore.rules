rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      // This function works for get, create, update, delete rules.
      // It cannot be used in list rules as get() is not allowed.
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }

    // User profiles (customer, driver, storeOwner) and their sub-collections are private to the owner
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Restaurants - public read, owner write
    match /restaurants/{restaurantId} {
      allow get, list: if true; // Public can view all restaurants and menus
      allow create: if isSignedIn(); // Any signed-in user can create a restaurant profile
      allow update, delete: if isRestaurantOwner(restaurantId);
    }

    // Menu items - public read, owner write
    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    // Orders collection
    match /orders/{orderId} {
      // Customer: Can list their own orders.
      allow list: if isSignedIn() && request.query.where.customerId == request.auth.uid;
      // Customer: Can create an order.
      allow create: if isSignedIn();
      // Customer: Can read, update, delete their own order.
      allow read, update, delete: if isOwner(resource.data.customerId);

      // Restaurant Owner: Can list orders for their restaurant.
      allow list: if isSignedIn() && request.query.where.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)/storeOwners/$(request.auth.uid)).data.restaurantId;
      // Restaurant Owner: Can read and update orders for their restaurant.
      allow read, update: if isRestaurantOwner(resource.data.restaurantId);
    }
    
    // OrderItems sub-collection
    match /orders/{orderId}/orderItems/{orderItemId} {
        // Access is inherited from the parent order document.
        // If a user can read the order, they can read the items.
        allow read: if get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
                       isRestaurantOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.restaurantId);
        // Only the order creator can create items for it (done in a batch).
        allow create: if get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid;
    }
  }
}
