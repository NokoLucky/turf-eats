rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are permissive and are intended for development/testing only.
    // They allow any authenticated user to read and write to any part of the database.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow collection group queries for drivers and store owners.
    // This is required for the Admin Dashboard's collectionGroup queries to work correctly,
    // as it allows the 'list' operation at the root level for these specific collection IDs.
    match /{path=**}/drivers/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/storeOwners/{ownerId} {
      allow read, write: if request.auth != null;
    }
  }
}
