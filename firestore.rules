rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      // This function can only be used for document-level (get, create, update, delete) rules, not list rules.
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }

    function getOrderData() {
      // Helper to get order data safely
      return resource.data;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantOwner(restaurantId);
    }

    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    match /orders/{orderId} {
      // Allow authenticated users to list orders with various query patterns
      allow list: if isSignedIn() && (
        // ADMIN/DEBUG: Allow listing all orders (you might want to restrict this)
        // Remove this if you want more strict rules
        request.auth.uid in ['admin-uid-here'] ||
        
        // Customer can list their own orders
        (request.query.keys().hasAny(['customerId']) && request.query.customerId == request.auth.uid) ||
        
        // Owner can list orders for their restaurant
        (request.query.keys().hasAny(['storeOwnerId']) && request.query.storeOwnerId == request.auth.uid) ||
        
        // Driver can list orders they have accepted
        (request.query.keys().hasAny(['driverId']) && request.query.driverId == request.auth.uid) ||
        
        // Driver can list available orders for pickup (no driver assigned)
        (request.query.keys().hasAny(['status']) && request.query.status == 'Preparing' && 
         (!request.query.keys().hasAny(['driverId']) || request.query.driverId == null))
      );
      
      // Customer: Can create an order for themselves.
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      // Read access based on role
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.storeOwnerId == request.auth.uid ||
        (resource.data.driverId != null && resource.data.driverId == request.auth.uid)
      );

      // Update access based on role and allowed fields
      allow update: if isSignedIn() && (
        // Customer can only update certain fields (like cancel)
        (resource.data.customerId == request.auth.uid && 
         request.resource.data.keys().hasOnly(['status']) && 
         request.resource.data.status in ['Cancelled']) ||
        
        // Restaurant owner can update order status
        (resource.data.storeOwnerId == request.auth.uid && 
         request.resource.data.keys().hasOnly(['status', 'estimatedTime', 'readyTime'])) ||
        
        // Driver can accept or update delivery status
        (request.auth.uid == request.resource.data.driverId && 
         request.resource.data.keys().hasOnly(['status', 'driverId', 'deliveryTime']))
      );
      
      // Customer can cancel/delete their own order
      allow delete: if isSignedIn() && resource.data.customerId == request.auth.uid;

      match /orderItems/{orderItemId} {
        // Read access same as parent order
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.storeOwnerId == request.auth.uid
        );
        
        // Only the customer can add items when creating order
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid;
      }
    }

    // Add specific driver collection if needed
    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }
  }
}