rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      // This function can only be used for document-level (get, create, update, delete) rules, not list rules.
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantOwner(restaurantId);
    }

    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    match /orders/{orderId} {
      // A consolidated 'list' rule for all roles.
      // The query's `where` clause must match one of these allowed patterns.
      // This is not a filter, but a validation of the query itself.
      allow list: if isSignedIn() && (
          (request.query.keys().hasAll(['customerId']) && request.query.customerId == request.auth.uid) ||
          (request.query.keys().hasAll(['storeOwnerId']) && request.query.storeOwnerId == request.auth.uid) ||
          (request.query.keys().hasAll(['driverId', 'status']) && request.query.driverId == request.auth.uid) ||
          (request.query.keys().hasAll(['status', 'driverId']) && request.query.status == 'Preparing' && request.query.driverId == null)
      );
      
      // Customer: Can create an order for themselves.
      allow create: if isOwner(request.resource.data.customerId);
      
      // Customer can read their own order.
      // Owner can read orders for their restaurant.
      // Driver can read orders they are assigned to.
      allow read: if isOwner(resource.data.customerId) || isOwner(resource.data.storeOwnerId) || isOwner(resource.data.driverId);

      // Customer, Owner, or Driver can update an order (e.g., status change).
      allow update: if isOwner(resource.data.customerId) || isOwner(resource.data.storeOwnerId) || isOwner(resource.data.driverId);
      
      // Customer can delete their own order (e.g. cancel).
      allow delete: if isOwner(resource.data.customerId);

      match /orderItems/{orderItemId} {
        // Access is inherited from the parent order document for reads.
        allow read: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.customerId) || isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.storeOwnerId);
        
        // Only the customer who created the order can add items to it.
        allow create: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.customerId);
      }
    }
  }
}
