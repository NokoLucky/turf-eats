/**
 * @fileoverview Firestore Security Rules for Turf Eats application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based and ownership-based access control model.
 * User profiles (Customer, Driver, StoreOwner) are strictly private and accessible only to the authenticated user.
 * Restaurants and MenuItems have public read access, but writes are restricted to the owning StoreOwner.
 * Orders and OrderItems have access control based on the associated Customer, Restaurant, or Driver.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Specific rules for user profile subcollections
    match /users/{userId}/customers/{customerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /users/{userId}/drivers/{driverId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /users/{userId}/storeOwners/{storeOwnerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /restaurants/{restaurantId} {
        allow get, list: if true;
        allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.storeOwnerId;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.storeOwnerId;
    }

    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }

    match /orders/{orderId} {
      function isOrderParticipant() {
        return request.auth.uid == resource.data.customerId || 
               request.auth.uid == resource.data.restaurantId || 
               request.auth.uid == resource.data.driverId;
      }
      
      allow get: if isSignedIn() && isOrderParticipant();
      allow list: if false; // Deny broad listing of orders for security
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isSignedIn() && isOrderParticipant();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.customerId; // Only customer can delete
    }

    match /orders/{orderId}/orderItems/{orderItemId} {
      function isParentOrderParticipant() {
        let order = get(/databases/$(database)/documents/orders/$(orderId)).data;
        return request.auth.uid == order.customerId || 
               request.auth.uid == order.restaurantId || 
               request.auth.uid == order.driverId;
      }

      allow read, write: if isSignedIn() && isParentOrderParticipant();
    }
  }
}
