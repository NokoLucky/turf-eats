rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isRestaurantOwner(restaurantId) {
      // Note: This function can't be used in 'list' rules directly
      // because get() is not allowed in list rules.
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.storeOwnerId == request.auth.uid;
    }

    // User profiles are private to the owner
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Restaurants - public read, owner write
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantOwner(restaurantId);
    }

    // Menu items - public read, owner write
    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantOwner(restaurantId);
    }

    // Orders
    match /orders/{orderId} {
      // Allow a user to query for their own orders.
      allow list: if isSignedIn() && request.query.where.customerId == request.auth.uid;
      // Allow a user to read their own specific order.
      allow get: if isSignedIn() && resource.data.customerId == request.auth.uid;
      // Allow a restaurant owner to read orders for their restaurant.
      allow get: if isRestaurantOwner(resource.data.restaurantId);
      // Allow create for any signed-in user.
      allow create: if isSignedIn();
      // Allow update/delete only for the customer who created it or the restaurant owner.
      allow update, delete: if (isSignedIn() && resource.data.customerId == request.auth.uid) || isRestaurantOwner(resource.data.restaurantId);
      
      // Order items can be read if the user can read the parent order.
      match /orderItems/{orderItemId} {
        allow read, list: if isSignedIn() && (get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid || isRestaurantOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.restaurantId));
        allow create: if isSignedIn(); // Batch writes in app handle security
      }
    }
  }
}
