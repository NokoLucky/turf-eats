rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY RULES FOR DEBUGGING - ALLOW ALL ACCESS FOR LOGGED-IN USERS
    // REMOVE THESE AFTER TESTING AND REPLACE WITH PROPER RULES
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow everything for signed-in users, deny for anonymous
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{userId}/customers/{customerId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{userId}/drivers/{driverId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{userId}/storeOwners/{storeOwnerId} {
      allow read, write: if isSignedIn();
    }

    // Restaurants - public read, any signed-in user can write
    match /restaurants/{restaurantId} {
      allow get, list: if true; // Public read
      allow create, update, delete: if isSignedIn(); // Any signed-in user can modify
    }

    // Menu items - public read, any signed-in user can write
    match /restaurants/{restaurantId}/menuItems/{menuItemId} {
      allow get, list: if true; // Public read
      allow create, update, delete: if isSignedIn(); // Any signed-in user can modify
    }

    // Orders - any signed-in user can do everything
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Order items - any signed-in user can do everything
    match /orders/{orderId}/orderItems/{orderItemId} {
      allow read, write: if isSignedIn();
    }

    // Catch-all for any other documents - allow for signed-in users
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
