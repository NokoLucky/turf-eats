rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow anyone to read files (e.g., for viewing images in the app).
      allow read;
      
      // Only allow authenticated users to write (upload, update, delete) files.
      // This is a critical security measure.
      allow write: if true;
    }
  }
}
