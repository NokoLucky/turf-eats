
{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer in the Pin2You application.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "userId", "name"]
    },
    "MenuItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MenuItem",
      "type": "object",
      "description": "Represents a menu item with optional customization groups.",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "promotionalPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isSoldOut": { "type": "boolean" },
        "category": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["radio", "checkbox"] },
              "choices": { "type": "array", "items": { "type": "string" } },
              "minSelections": { "type": "number" },
              "maxSelections": { "type": "number" },
              "isRequired": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["id", "restaurantId", "name", "price", "category"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "menuItemId": { "type": "string" },
        "quantity": { "type": "number" },
        "itemPrice": { "type": "number" },
        "name": { "type": "string" },
        "selectedOptions": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/customers/{customerId}",
        "definition": { "entityName": "Customer", "schema": { "$ref": "#/backend/entities/Customer" }, "description": "Stores customer profiles." }
      },
      {
        "path": "/restaurants/{restaurantId}/menuItems/{menuItemId}",
        "definition": { "entityName": "MenuItem", "schema": { "$ref": "#/backend/entities/MenuItem" }, "description": "Stores menu items with options." }
      },
      {
        "path": "/orders/{orderId}",
        "definition": { "entityName": "Order", "schema": { "$ref": "#/backend/entities/Order" }, "description": "Stores order information." }
      },
      {
        "path": "/orders/{orderId}/orderItems/{orderItemId}",
        "definition": { "entityName": "OrderItem", "schema": { "$ref": "#/backend/entities/OrderItem" }, "description": "Stores customized items within an order." }
      }
    ],
    "reasoning": "Standard Firestore structure with sub-collections for menu items and order items to support deep customization."
  }
}
